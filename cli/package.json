{
	"name": "@as-harness/cli",
	"version": "0.1.0",
	"license": "MIT",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"bin": {
		"as-harness": "./index.ts"
	},
	"scripts": {
		"dev": "bun run ./index.ts",
		"clean": "bun run ./build.ts --clean",
