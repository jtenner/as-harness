		"build:release": "bun run ./build.ts --release-targets",
		"build:list-release-targets": "bun run ./build.ts --list-release-targets"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/bun": "latest"
	},
	"dependencies": {
		"assemblyscript": "^0.28.10"
	}
}
